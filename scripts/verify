#!/bin/bash
# Single verification entrypoint. CI and AGENTS.md both defer to this file,
# so the gate lives in exactly one place. Mirrors the unconditional Go gates
# in .github/workflows/ci.yml (govulncheck and the web/dist drift check need
# network/npm and run in CI only).
set -euo pipefail
cd "$(dirname "$0")/.."

unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
  echo "gofmt needed on:" >&2
  echo "$unformatted" >&2
  exit 1
fi

go vet ./...
go build ./...
go test ./...
